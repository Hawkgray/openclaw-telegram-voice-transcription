{
  "$schema": "https://docs.openclaw.ai/schemas/config/v1.json",
  "version": "1.0",
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "language": "ru",
        "echoTranscript": true,
        "echoFormat": "📝 {transcript}",
        "models": [
          {
            "type": "cli",
            "command": "python3",
            "args": [
              "{{UserHome}}/.openclaw/workspace/scripts/transcribe_faster_whisper.py",
              "{{MediaPath}}"
            ],
            "timeoutSeconds": 180
          }
        ]
      }
    }
  }
}
